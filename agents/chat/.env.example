# 対話エージェント (agents/chat) の環境変数
# 値はハードコードせずここから注入する。実値は .env に記載（.env は .gitignore 済み）。

# 東京リージョン固定
AWS_REGION=ap-northeast-1

# Bedrock の Claude 推論プロファイル（日本国内完結の jp.* を使用）
# 最新IDは `aws bedrock list-inference-profiles --region ap-northeast-1` で確認する
BEDROCK_MODEL_ID=jp.anthropic.claude-sonnet-4-5-20250929-v1:0

# CDK(EvoStack) のデプロイ出力を転記
MEMORY_ID=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
