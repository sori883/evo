# Next.js (Vercel) の環境変数。実値は .env.local に記載（.gitignore 済み）。
AWS_REGION=ap-northeast-1

# CDK(EvoStack) のデプロイ出力を転記
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# AgentCore Runtime の invoke エンドポイント（Bearer 付き HTTPS で直叩き）
# 実URLは実デプロイ時に確認して設定する
AGENT_RUNTIME_URL=

# --- E2E (Playwright / 実 AWS 接続) 用 ---
# E2E_BASE_URL を指定すると既存サーバに対して実行（未指定はローカル起動）
E2E_BASE_URL=
E2E_USER_EMAIL=e2e@example.com
E2E_USER_PASSWORD=
