# Next.js (Vercel) / ローカル E2E の環境変数。
# 実値は .env.local に記載（.gitignore 済み）。playwright.config が .env.local を読むため
# ローカル E2E では値をここに集約すれば実行時の export は不要。

AWS_REGION=ap-northeast-1

# AWS 認証（BFF が Cognito を、E2E の global-setup が Cognito 管理 API を呼ぶ）。
# アクセスキーは直書きせず、プロファイル名 or 標準認証チェーン（環境のクレデンシャル）を使う。
AWS_PROFILE=

# CDK(EvoStack) のデプロイ出力を転記
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# AgentCore Runtime の invoke エンドポイント（実デプロイ時に確定）
AGENT_RUNTIME_URL=

# --- ローカル E2E (Playwright / 実 AWS 接続) ---
# E2E_BASE_URL を指定すると既存サーバに対して実行（未指定はローカル起動）
E2E_BASE_URL=
E2E_USER_EMAIL=e2e@example.com
E2E_USER_PASSWORD=
