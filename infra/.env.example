# CDK (EvoStack) デプロイ用の環境変数。実値は .env に記載（.gitignore 済み）。
AWS_REGION=ap-northeast-1
CDK_DEFAULT_ACCOUNT=

# Bedrock の Claude 推論プロファイル（日本国内完結 jp.*）
# 最新IDは `aws bedrock list-inference-profiles --region ap-northeast-1` で確認
BEDROCK_MODEL_ID=jp.anthropic.claude-sonnet-4-5-20250929-v1:0

# AgentCore Runtime
AGENT_RUNTIME_NAME=evo_chat
# CodeZip の managed runtime 識別子（実デプロイ時に docs/CLI で正式値を確認）
AGENT_MANAGED_RUNTIME=NODEJS_22
