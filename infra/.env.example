# CDK (EvoStack) デプロイ用の環境変数。実値は .env に記載（.gitignore 済み）。
AWS_REGION=ap-northeast-1
CDK_DEFAULT_ACCOUNT=

# Bedrock の Claude 推論プロファイル（日本国内完結 jp.*）
# 最新IDは `aws bedrock list-inference-profiles --region ap-northeast-1` で確認
BEDROCK_MODEL_ID=jp.anthropic.claude-sonnet-4-5-20250929-v1:0

# AgentCore Runtime
AGENT_RUNTIME_NAME=evo_chat
# CodeZip の managed runtime 識別子（実デプロイ時に docs/CLI で正式値を確認）
AGENT_MANAGED_RUNTIME=NODE_22

# incident エージェント専用モデル（ここで ID を指定。未設定なら BEDROCK_MODEL_ID）
INCIDENT_MODEL_ID=jp.anthropic.claude-haiku-4-5-20251001-v1:0

# 対象リポジトリ（未設定なら sori883/evo）
# GITHUB_REPO=sori883/evo

# incident の PR 作成用 fine-grained PAT（Contents R/W + Pull requests R/W, repo=sori883/evo）
# 未設定なら incident は diagnosis のみ（PR 機能オフ）。secret 名は GitHub Actions と統一。
# EVO_GITHUB_PAT=github_pat_xxx
