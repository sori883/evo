{
  "name": "evo",
  "version": "0.1.0",
  "private": true,
  "description": "AgentCore x Strands(TS) ambient/conversational agents",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "dev:agent": "pnpm --filter @evo/agent-chat dev",
    "dev:web": "pnpm --filter @evo/web dev",
    "cdk": "pnpm --filter @evo/infra cdk"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
